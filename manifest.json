{
  "manifest_version": 3,
  "name": "X-Scraper",
  "version": "0.2.0",
  "description": "Extract X (Twitter) threads, replies, and bookmarks as Markdown, JSON, or plain text. Includes metrics, resource harvesting, webhook integration, and bookmark archiving.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "downloads"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "shared/scraper.js"
      ],
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ]
    }
  ]
}